# Server Configuration
PORT=3000

# Database Configuration (PostgreSQL)
# Adjust the credentials and host/port as needed for your environment.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/edupub_manager?schema=public"

# JWT Authentication
JWT_SECRET="super_secret_jwt_key_change_me_in_production"
JWT_EXPIRES_IN="1d"

# Security
BCRYPT_SALT_ROUNDS=10
